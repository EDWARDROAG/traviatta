# ======================================================
# ARCHIVO: .env.example
# UBICACIÓN: menu-qr-system/backend/.env.example
# FASE: F0
# VERSIÓN: 1.0
# ÚLTIMA ACTUALIZACIÓN: 2024-01-16 09:00
#
# 🎯 PROPÓSITO:
# Plantilla de variables de entorno para el backend.
# Copiar a .env y completar con valores reales.
#
# 📦 DEPENDENCIAS:
# - Ninguna
#
# 🔗 RELACIONES:
# - Es importado por: config/*, app.js, server.js
#
# 📋 HISTORIAL DE CAMBIOS:
# ------------------------------------------------------
# 1.0 - 2024-01-16 09:00
#    ✅ Creación inicial del archivo
#    ✅ Variables para base de datos
#    ✅ Variables para Redis, RabbitMQ
#    ✅ Variables para Cloudinary
#    ✅ Configuración de JWT y CORS
# ======================================================

# ======================================================
# ENTORNO
# ======================================================
NODE_ENV=development
PORT=3005

# ======================================================
# BASE DE DATOS (PostgreSQL)
# ======================================================
DATABASE_URL=postgresql://menu_user:secure_password@localhost:5432/menu_db
DATABASE_URL_REPLICA_1=postgresql://menu_user:secure_password@localhost:5433/menu_db
DATABASE_URL_REPLICA_2=postgresql://menu_user:secure_password@localhost:5434/menu_db

DB_USER=menu_user
DB_PASSWORD=secure_password
DB_NAME=menu_db
DB_PORT=5432
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000
DB_SSL=false

# ======================================================
# REDIS (Caché)
# ======================================================
REDIS_URL=redis://localhost:6380
REDIS_PORT=6380

# ======================================================
# RABBITMQ (Colas)
# ======================================================
RABBITMQ_URL=amqp://guest:guest@localhost:5673
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_AMQP_PORT=5673
RABBITMQ_MGMT_PORT=15673

# ======================================================
# CLOUDINARY (Imágenes)
# ======================================================
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ======================================================
# AUTENTICACIÓN JWT
# ======================================================
JWT_SECRET=tu_super_secret_key_cambiar_en_produccion
JWT_EXPIRES_IN=7d

# ======================================================
# CORS
# ======================================================
CORS_ORIGINS=http://localhost:8080,http://localhost:3006,http://localhost:5173

# ======================================================
# LOGGING
# ======================================================
LOG_LEVEL=debug