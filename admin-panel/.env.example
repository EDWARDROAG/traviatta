# ======================================================
# ARCHIVO: .env.example
# UBICACIÓN: menu-qr-system/admin-panel/.env.example
# FASE: F2
# VERSIÓN: 1.0
# ÚLTIMA ACTUALIZACIÓN: 2024-01-17 01:45
#
# 🎯 PROPÓSITO:
# Plantilla de variables de entorno para el panel
# administrativo. Copiar este archivo a .env y
# modificar según entorno.
#
# 📋 INSTRUCCIONES:
# 1. Copiar este archivo como .env
# 2. Reemplazar los valores según el entorno
# 3. Nunca commitear el archivo .env al repositorio
# ======================================================

# ======================================================
# API CONFIGURATION
# ======================================================

# URL base de la API backend
# Desarrollo local: http://localhost:3005/api
# Producción: /api (relativo, usando proxy)
VITE_API_URL=/api

# ======================================================
# APP CONFIGURATION
# ======================================================

# Título de la aplicación
VITE_APP_TITLE=Menu QR Plus - Admin

# ======================================================
# FEATURE FLAGS
# ======================================================

# Habilitar modo oscuro (true/false)
VITE_ENABLE_DARK_MODE=false

# Habilitar exportación de reportes (true/false)
VITE_ENABLE_EXPORTS=true

# ======================================================
# PAGINACIÓN
# ======================================================

# Items por página por defecto
VITE_DEFAULT_PAGE_SIZE=20

# ======================================================
# ENTORNO
# ======================================================

# Entorno: development, production, test
VITE_ENV=development