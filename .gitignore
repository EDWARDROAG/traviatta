# ======================================================
# ARCHIVO: .gitignore
# UBICACIÓN: menu-qr-system/.gitignore
# FASE: F0
# VERSIÓN: 1.0
# ÚLTIMA ACTUALIZACIÓN: 2024-01-16 10:30
#
# 🎯 PROPÓSITO:
# Especifica qué archivos y directorios deben ser
# ignorados por Git. Protege información sensible,
# dependencias, logs y archivos generados.
# ======================================================

# ======================================================
# DEPENDENCIAS
# ======================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ======================================================
# ENTORNO Y CONFIGURACIÓN
# ======================================================

.env
.env.local
.env.production
.env.development
.env.test
*.env

# ======================================================
# BUILD OUTPUTS
# ======================================================

dist/
build/
.next/
out/
*.tsbuildinfo

# ======================================================
# DOCKER
# ======================================================

*.log
*.pid
*.seed
docker-compose.override.yml

# ======================================================
# IDE Y EDITORES
# ======================================================

.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.suo
*.user
*.userosscache
*.sln.docstates

# ======================================================
# ARCHIVOS DE RESPALDO
# ======================================================

*.bak
*.sql.gz
*.tar.gz
*.zip
*.backup

# ======================================================
# LOGS
# ======================================================

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pm2-*.log

# ======================================================
# COBERTURA DE TESTS
# ======================================================

coverage/
.nyc_output/
*.lcov
*.lcov.info

# ======================================================
# UPLOADS TEMPORALES
# ======================================================

uploads/
temp/
tmp/
*.tmp

# ======================================================
# BASE DE DATOS LOCAL
# ======================================================

*.sqlite
*.sqlite3
*.db

# ======================================================
# ARCHIVOS DEL SISTEMA
# ======================================================

.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ======================================================
# SECRETOS Y CERTIFICADOS
# ======================================================

*.pem
*.key
*.crt
*.p12
.secrets/

# ======================================================
# ARCHIVOS ESPECÍFICOS DEL PROYECTO
# ======================================================

# Backend
backend/uploads/
backend/logs/

# Frontend
frontend/dist/
frontend/.env

# Admin panel
admin-panel/dist/
admin-panel/.env

# ======================================================
# HERRAMIENTAS DE DESARROLLO
# ======================================================

.eslintcache
.prettierrc
.tern-port