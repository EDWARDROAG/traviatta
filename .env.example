# ======================================================
# ARCHIVO: .env.example
# UBICACIÓN: menu-qr-system/backend/.env.example
# FASE: F0
# VERSIÓN: 1.0
# ÚLTIMA ACTUALIZACIÓN: 2024-01-16 10:00
#
# 🎯 PROPÓSITO:
# Plantilla de variables de entorno para el backend.
# Copiar este archivo a .env y completar con valores reales.
#
# 📋 INSTRUCCIONES:
# 1. Copiar este archivo como .env
# 2. Reemplazar los valores de ejemplo con los reales
# 3. Nunca commitear el archivo .env al repositorio
# ======================================================

# ======================================================
# NODE ENVIRONMENT
# ======================================================

# Entorno: development, production, test
NODE_ENV=development

# Puerto del servidor
PORT=3005

# Nivel de log: error, warn, info, http, debug
LOG_LEVEL=info

# ======================================================
# BASE DE DATOS (PostgreSQL)
# ======================================================

# URL principal de conexión (master)
DATABASE_URL=postgresql://menu_user:secure_password@localhost:5432/menu_db

# Read replicas (para escalabilidad)
DATABASE_URL_REPLICA_1=postgresql://menu_user:secure_password@localhost:5433/menu_db
DATABASE_URL_REPLICA_2=postgresql://menu_user:secure_password@localhost:5434/menu_db

# Configuración de pool
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000
DB_SSL=false

# ======================================================
# REDIS (Caché)
# ======================================================

# URL de conexión a Redis
REDIS_URL=redis://localhost:6380

# Puerto alternativo si hay conflicto
REDIS_PORT=6380

# ======================================================
# RABBITMQ (Colas)
# ======================================================

# URL de conexión a RabbitMQ
RABBITMQ_URL=amqp://localhost:5673

# Credenciales
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Puertos
RABBITMQ_AMQP_PORT=5673
RABBITMQ_MGMT_PORT=15673

# ======================================================
# JWT (Autenticación)
# ======================================================

# Secreto para firmar tokens (cambiar en producción)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Tiempo de expiración
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ======================================================
# CLOUDINARY (Imágenes)
# ======================================================

# Credenciales de Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ======================================================
# WHATSAPP (Opcional - Business API)
# ======================================================

# Número de WhatsApp del restaurante (formato internacional)
WHATSAPP_NUMBER=573001112233

# Token de verificación para webhooks
WHATSAPP_VERIFY_TOKEN=your_verify_token

# Access token para API
WHATSAPP_ACCESS_TOKEN=your_access_token

# Phone number ID (Meta)
WHATSAPP_PHONE_NUMBER_ID=123456789

# ======================================================
# FRONTEND URL (para generar QRs)
# ======================================================

# URL pública del frontend
FRONTEND_URL=https://menu.dominio.com

# ======================================================
# CORS
# ======================================================

# Orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:3006,https://menu.dominio.com

# ======================================================
# RATE LIMITING
# ======================================================

# Máximo de peticiones por minuto
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ======================================================
# OPCIONALES
# ======================================================

# Modo mantenimiento
MAINTENANCE_MODE=false

# Tiempo de caché por defecto (segundos)
DEFAULT_CACHE_TTL=300