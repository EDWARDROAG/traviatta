# ======================================================
# ARCHIVO: .env.example
# UBICACIÓN: menu-qr-system/frontend/.env.example
# FASE: F1
# VERSIÓN: 1.0
# ÚLTIMA ACTUALIZACIÓN: 2024-01-16 18:00
#
# 🎯 PROPÓSITO:
# Plantilla de variables de entorno para el frontend.
# Copiar este archivo a .env y modificar según entorno.
#
# 📋 INSTRUCCIONES:
# 1. Copiar este archivo como .env
# 2. Reemplazar los valores según el entorno
# 3. Nunca commitear el archivo .env al repositorio
# ======================================================

# ======================================================
# API CONFIGURATION
# ======================================================

# URL base de la API backend
# Desarrollo local: http://localhost:3005/api
# Producción: /api (relativo, usando proxy)
VITE_API_URL=/api

# ======================================================
# APP CONFIGURATION
# ======================================================

# Título de la aplicación
VITE_APP_TITLE=Menú Digital QR

# Puerto Vite (8080 suele estar ocupado en este PC)
VITE_DEV_PORT=8081

# true = carta desde staticMenus (sin backend). false = llamar API vía proxy.
VITE_USE_STATIC_MENU=true

# Proxy backend (solo si VITE_USE_STATIC_MENU=false y el API está arriba)
VITE_PROXY_TARGET=http://localhost:3005

# URL base de la aplicación (para generación de QR)
VITE_APP_URL=https://menu.dominio.com

# ======================================================
# WHATSAPP CONFIGURATION
# ======================================================

# Número por defecto para WhatsApp (opcional)
VITE_DEFAULT_WHATSAPP=3193856893

# ======================================================
# FEATURE FLAGS
# ======================================================

# Habilitar modo oscuro (true/false)
VITE_ENABLE_DARK_MODE=false

# Habilitar búsqueda de productos (true/false)
VITE_ENABLE_SEARCH=true

# Habilitar reseñas de productos (true/false)
VITE_ENABLE_REVIEWS=false

# ======================================================
# ANALYTICS (opcional)
# ======================================================

# Google Analytics ID (opcional)
# VITE_GA_ID=G-XXXXXXXXXX

# ======================================================
# ENTORNO
# ======================================================

# Entorno: development, production, test
VITE_ENV=development